# ADIRD — Environment Variables Template
# Copy to .env.dev for local, .env for production

APP_ENV=development
APP_PORT=8080
LOG_LEVEL=info

DATABASE_URL=postgres://adird:PASSWORD@localhost:5432/adird_dev?sslmode=disable
REDIS_URL=redis://localhost:6379

MQTT_BROKER_URL=tcp://localhost:1883
MQTT_CLIENT_ID=vidi-backend-01
MQTT_USERNAME=vidi
MQTT_PASSWORD=

OSRM_URL=http://localhost:5000

JWT_SECRET=
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=720h

SMS_PROVIDER=console
VONAGE_API_KEY=
VONAGE_API_SECRET=

FCM_PROVIDER=console
FCM_SERVICE_ACCOUNT_JSON=

MIDTRANS_ENV=sandbox
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
